  m_Script: {fileID: 11500000, guid: 835414981edeb4f51b37ed3dcc34ee00, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _textMeshPro: {fileID: 147031089}
  stringArray:
  - "Mmmm, the moon\u2019s tears... smooth and bitter. You don\u2019t understand,
    do you? The soap scrubs the filth from my soul, polishes my insides. Each bubble
    holds a truth, a secret someone tried to hide. They came to me seeking answers,
    and now their whispers are trapped in the foam."
  timeBtwCharacters: 0.05
  timeBtwWords: 0.3
  typingSound: {fileID: 147031087}
